# PostgreSQL — use localhost when running the GUI on your host machine
# Use DB_HOST=db when the Python app runs inside the same Docker Compose network

DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Schema where lab tables live (auto-detected if different)
DB_SCHEMA=labs

# Connection pool
DB_POOL_MIN=1
DB_POOL_MAX=10

# GUI
APP_TITLE=Medical Laboratory Management System
APP_APPEARANCE=dark
APP_COLOR_THEME=blue
